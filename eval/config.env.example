# 复制为 eval/config.env 后修改

# OpenAI 兼容 API（不要带 /chat/completions 后缀）
VLLM_BASE_URL=http://127.0.0.1:50600/v1
VLLM_CHAT_URL=http://127.0.0.1:50600/v1/chat/completions
VLLM_MODEL_ID=/models/Qwen3.6-27B

# HuggingFace / ModelScope tokenizer（EvalScope perf 随机数据集需要）
TOKENIZER_PATH=Qwen/Qwen3.6-27B

# 性能：deploy benchmark 标签
BENCH_LABEL=prod-local

# 能力：quick=冒烟 limit 20；standard=正式 limit 100（耗时长）
CAP_EVAL_LIMIT_QUICK=20
CAP_EVAL_LIMIT_STANDARD=100
